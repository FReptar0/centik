generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ---

enum TransactionType {
  INCOME
  EXPENSE
}

enum Frequency {
  QUINCENAL
  MENSUAL
  SEMANAL
  VARIABLE
}

enum DebtType {
  CREDIT_CARD
  PERSONAL_LOAN
  AUTO_LOAN
  OTHER
}

enum PaymentMethod {
  EFECTIVO
  DEBITO
  CREDITO
  TRANSFERENCIA
}

enum CategoryType {
  EXPENSE
  INCOME
  BOTH
}

enum AssetCategory {
  PPR
  INVESTMENT
  SAVINGS
  CRYPTO
  OTHER
}

// --- Auth Models (v3.0) ---

/// User model for authentication and data ownership
model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  isApproved     Boolean   @default(false)
  isAdmin        Boolean   @default(false)
  totpSecret     String?
  totpEnabled    Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  transactions     Transaction[]
  incomeSources    IncomeSource[]
  categories       Category[]
  debts            Debt[]
  budgets          Budget[]
  periods          Period[]
  monthlySummaries MonthlySummary[]
  valueUnits       ValueUnit[]
  unitRates        UnitRate[]
  assets           Asset[]
  inviteTokens     InviteToken[]
  backupCodes      BackupCode[]
}

/// Auth.js adapter - OAuth/credential accounts
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

/// Auth.js adapter - User sessions
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Auth.js adapter - Email verification tokens
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Invite tokens for registration (v3.0 invite-only)
model InviteToken {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  revokedAt DateTime?
  createdBy String
  createdAt DateTime  @default(now())

  creator User @relation(fields: [createdBy], references: [id])
}

// --- MVP Models (DFR 2.1 - 2.7) ---

/// DFR 2.1 - Income sources (employment, freelance, other)
model IncomeSource {
  id            String    @id @default(cuid())
  name          String    @unique
  defaultAmount BigInt
  frequency     Frequency
  type          String // "EMPLOYMENT", "FREELANCE", "OTHER" — not an enum per DFR
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  userId        String

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
}

/// DFR 2.2 - Financial transactions (income and expense)
model Transaction {
  id             String          @id @default(cuid())
  type           TransactionType
  amount         BigInt
  description    String?
  categoryId     String
  incomeSourceId String?
  date           DateTime        @db.Date
  paymentMethod  PaymentMethod?
  periodId       String
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  userId         String

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     Category      @relation(fields: [categoryId], references: [id])
  incomeSource IncomeSource? @relation(fields: [incomeSourceId], references: [id])
  period       Period        @relation(fields: [periodId], references: [id])

  @@index([periodId, date])
  @@index([categoryId])
  @@index([userId])
}

/// DFR 2.3 - Expense and income categories
model Category {
  id        String       @id @default(cuid())
  name      String       @unique
  icon      String
  color     String
  type      CategoryType
  isDefault Boolean      @default(false)
  isActive  Boolean      @default(true)
  sortOrder Int          @default(0)
  userId    String

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]

  @@index([userId])
}

/// DFR 2.4 - Debts (credit cards, loans)
model Debt {
  id              String   @id @default(cuid())
  name            String   @unique
  type            DebtType
  currentBalance  BigInt
  creditLimit     BigInt?
  annualRate      Int // basis points (4500 = 45.00%)
  minimumPayment  BigInt?
  monthlyPayment  BigInt?
  originalAmount  BigInt?
  remainingMonths Int?
  cutOffDay       Int?
  paymentDueDay   Int?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// DFR 2.5 - Budget allocations per category per period
model Budget {
  id              String   @id @default(cuid())
  categoryId      String
  quincenalAmount BigInt
  periodId        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])
  period   Period   @relation(fields: [periodId], references: [id])

  @@unique([periodId, categoryId, userId])
  @@index([userId])
}

/// DFR 2.6 - Calendar month periods
model Period {
  id        String    @id @default(cuid())
  month     Int
  year      Int
  startDate DateTime  @db.Date
  endDate   DateTime  @db.Date
  isClosed  Boolean   @default(false)
  closedAt  DateTime?
  createdAt DateTime  @default(now())
  userId    String

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  budgets        Budget[]
  monthlySummary MonthlySummary?

  @@unique([month, year, userId])
  @@index([userId])
}

/// DFR 2.7 - Monthly summary snapshot created on period close
model MonthlySummary {
  id            String   @id @default(cuid())
  periodId      String   @unique
  totalIncome   BigInt
  totalExpenses BigInt
  totalSavings  BigInt
  savingsRate   Int // basis points (2050 = 20.50%)
  debtAtClose   BigInt
  debtPayments  BigInt
  notes         String?
  createdAt     DateTime @default(now())
  userId        String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  period Period @relation(fields: [periodId], references: [id])

  @@index([userId])
}

// --- v2 Models (DFR 2.8 - 2.10) ---

/// DFR 2.8 - Value units for tracking assets in non-MXN denominations
model ValueUnit {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  precision       Int
  symbol          String?
  providerUrl     String?
  providerPath    String?
  providerHeaders Json?
  refreshInterval Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          String

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  rates  UnitRate[]
  assets Asset[]

  @@index([userId])
}

/// DFR 2.9 - Historical conversion rates from value units to MXN centavos
model UnitRate {
  id             String   @id @default(cuid())
  unitId         String
  date           DateTime @db.Date
  rateToMxnCents BigInt
  rateRaw        String
  source         String
  createdAt      DateTime @default(now())
  userId         String

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  unit ValueUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, date])
  @@index([unitId])
  @@index([userId])
}

/// DFR 2.10 - Assets and investments tracked in value units
model Asset {
  id          String        @id @default(cuid())
  name        String
  unitId      String
  amount      BigInt
  category    AssetCategory
  institution String?
  notes       String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  userId      String

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  unit ValueUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@index([userId])
}

/// Single-use backup codes for 2FA recovery (v3.0 TOTP — D-09, D-28)
model BackupCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
