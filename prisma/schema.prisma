// Prisma schema -- full schema defined in Phase 2
// This minimal file exists so `prisma generate` succeeds during postinstall

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Stub model for toolchain validation. Full schema in Phase 2.
model Period {
  id        String   @id @default(cuid())
  month     Int
  year      Int
  isClosed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([month, year])
}
